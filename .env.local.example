# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored and must NEVER be committed.

# Your Anthropic API key — powers the real LLM agent calls.
ANTHROPIC_API_KEY=sk-ant-...

# GitHub integration for Feature 1 (the synchronous gate / real PR).
# The token MUST be fine-grained and scoped to ONLY the throwaway repo,
# with Contents: read/write and Pull requests: read/write. See SETUP_GITHUB.md.
# If these are omitted, the demo still runs and simply reports GitHub was skipped.
GITHUB_TOKEN=github_pat_...
GITHUB_OWNER=your-username-or-org
GITHUB_REPO=governance-demo-prs

# Optional override of the agent model. Defaults to claude-sonnet-4-6.
AGENT_MODEL=claude-sonnet-4-6
